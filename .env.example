# Database (required at runtime for auth / API routes; not required only for `next build` — add in Vercel → Settings → Environment Variables for production)
DATABASE_URL=postgresql://user:password@localhost:5432/haze

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional - for Google/GitHub sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (optional - for verification emails)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# AI — Claude (Anthropic) is used first when set; then OpenAI. UI generation + /api/ai/chat-completions use these.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional alias for the same key (either ANTHROPIC_API_KEY or CLAUDE_API_KEY is enough)
# CLAUDE_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_SKIP_JSON_RESPONSE_FORMAT=

# Site (optional - dashboard links)
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@haze.app
