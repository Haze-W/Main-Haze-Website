# Database (required for auth)
DATABASE_URL=postgresql://user:password@localhost:5432/haze

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional - for Google/GitHub sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (optional - for verification emails)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# AI — OpenAI Chat Completions API (https://api.openai.com/v1)
OPENAI_API_KEY=
# Optional: custom base URL (e.g. enterprise gateway). Default: https://api.openai.com/v1
OPENAI_BASE_URL=
# Default model when the request omits model (default: gpt-4o-mini for speed; set gpt-4o for max quality)
OPENAI_MODEL=
# Set to 1 if your gateway rejects response_format json_object (JSON mode for tools)
OPENAI_SKIP_JSON_RESPONSE_FORMAT=
ANTHROPIC_API_KEY=

# Site (optional - dashboard links)
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@haze.app
